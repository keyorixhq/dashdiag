#!/bin/sh
# AppRun for the dsd AppImage. dsd is a single static CLI binary, so this is a
# thin shim: resolve the bundle root, then exec the binary with every argument
# forwarded verbatim. No env mangling — dsd reads /proc and /sys directly and
# must see the host's real namespaces, not a sandboxed view.
HERE="$(dirname "$(readlink -f "$0")")"
exec "${HERE}/usr/bin/dsd" "$@"
