#!/bin/bash
# Pre-push: thorough checks before code reaches GitHub — target < 90 seconds
# Install: cp scripts/hooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push

set -e
echo "→ Pre-push (thorough checks)"

# 1. Full test suite with race detector
echo "  Running tests with race detector..."
if ! go test -race -count=1 -timeout 90s ./... 2>&1; then
    echo "❌ Tests failed (race detector)"
    exit 1
fi
echo "  ✅ tests (race)"

# 2. golangci-lint — full linter suite
if command -v golangci-lint &>/dev/null; then
    echo "  Running golangci-lint..."
    if ! golangci-lint run ./... 2>&1; then
        echo "❌ golangci-lint failed"
        echo "   Fix issues then: git push"
        exit 1
    fi
    echo "  ✅ golangci-lint"
else
    echo "  ⚠️  golangci-lint not installed — run: make tools"
    echo "  Skipping lint check"
fi

# 3. staticcheck (if installed)
if command -v staticcheck &>/dev/null; then
    echo "  Running staticcheck..."
    if ! staticcheck ./... 2>&1; then
        echo "❌ staticcheck failed"
        exit 1
    fi
    echo "  ✅ staticcheck"
fi

# 4. gosec via golangci-lint — single source of truth for excludes is
# .golangci.yml (no standalone exclude list to drift; ADR-0007 lesson).
if command -v golangci-lint &>/dev/null; then
    echo "  Running gosec (via golangci-lint config)..."
    if ! golangci-lint run --enable-only=gosec ./... 2>&1; then
        echo "❌ gosec found security issues"
        exit 1
    fi
    echo "  ✅ gosec"
fi

# 5. semgrep custom rules — blocking set (ERROR+WARNING), mirrors CI.
# The INFO audit layer is intentionally excluded here; run `make security-audit`.
# Resolve paths from the repo root so the hook works regardless of git's CWD.
if command -v semgrep &>/dev/null; then
    echo "  Running semgrep (custom rules, blocking set)..."
    ROOT="$(git rev-parse --show-toplevel)"
    if ! semgrep scan --config "$ROOT/.semgrep/" --error --severity ERROR --severity WARNING --quiet "$ROOT" 2>/dev/null; then
        echo "❌ semgrep found security issues"
        exit 1
    fi
    echo "  ✅ semgrep"
else
    echo "  ⚠️  semgrep not installed — brew install semgrep (skipping)"
fi

echo ""
echo "✅ Pre-push passed — pushing to GitHub"
