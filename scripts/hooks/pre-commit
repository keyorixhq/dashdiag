#!/bin/bash
# Pre-commit: fast checks only — target < 20 seconds
# Install: cp scripts/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -e
echo "→ Pre-commit (fast checks)"

# 1. Format check — instant
if [ -n "$(gofmt -l .)" ]; then
    echo ""
    echo "❌ Files need formatting. Run: make fmt"
    echo ""
    gofmt -l .
    exit 1
fi
echo "  ✅ gofmt"

# 2. go vet — 2-5 seconds, catches real bugs
if ! go vet ./... 2>&1; then
    echo "❌ go vet failed"
    exit 1
fi
echo "  ✅ go vet"

# 3. Tests with -short flag — skips slow integration tests, keeps it under 15s
if ! go test -short -count=1 -timeout 30s ./... 2>&1; then
    echo "❌ Tests failed"
    exit 1
fi
echo "  ✅ tests (short)"

echo ""
echo "✅ Pre-commit passed — run 'make check' for full lint before pushing"
